{
  "name": "pinterest-pin-publisher",
  "version": "1.0.3",
  "description": "Safe, user-controlled Pinterest publishing assistant for Windows desktop.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "package": "npm run build && electron-builder --win",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "pinterest",
    "pin",
    "publisher",
    "electron",
    "react",
    "playwright"
  ],
  "author": "Antigravity Pair Programmer",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.395.0",
    "playwright": "^1.44.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.pinterest.pinpublisher",
    "productName": "Pinterest Pin Publisher",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ]
  }
}
