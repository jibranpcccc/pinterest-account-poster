{
  "name": "pinterest-pin-publisher",
  "version": "1.0.13",
  "description": "Safe, user-controlled Pinterest publishing assistant for Windows desktop.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "package": "npm run build && electron-builder --win --publish never",
    "package:ci": "npm run build && electron-builder --win --publish always",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "pinterest",
    "pin",
    "publisher",
    "electron",
    "react",
    "playwright"
  ],
  "author": "Pinterest Pin Publisher",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.395.0",
    "playwright": "^1.44.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.pinpublisher.app",
    "productName": "Pinterest Pin Publisher",
    "copyright": "Copyright © 2026 Pinterest Pin Publisher",
    "npmRebuild": false,
    "forceCodeSigning": false,
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json",
      "cloudflare_accounts.txt",
      "node_modules/**/*",
      "!**/.git/**",
      "!**/node_modules/.cache/**",
      "!**/local-data/**",
      "!**/*.log",
      "!**/cloudflare_working_accounts.txt",
      "!**/node_modules/sqlite3/**",
      "!**/node_modules/playwright-core/.local-browsers/**"
    ],
    "asarUnpack": [
      "node_modules/playwright/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/playwright-core/.local-browsers",
        "to": "playwright-browsers",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pinterest Pin Publisher",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
